{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.secapp.dev/v1/collector-execution.schema.json",
  "title": "SecApp CollectorExecution",
  "description": "State-exclusive lifecycle and bounded result contract for one collector invocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_id",
    "run_id",
    "pass_id",
    "collector_id",
    "collector_version",
    "collector_definition_digest",
    "state",
    "privilege",
    "consent_receipt_ids",
    "observation_ids",
    "errors",
    "integrity"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "execution_id": {
      "type": "string",
      "format": "uuid"
    },
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "pass_id": {
      "type": "string",
      "format": "uuid"
    },
    "collector_id": {
      "type": "string",
      "pattern": "^collector:[a-z0-9][a-z0-9._-]{0,63}:[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "collector_version": {
      "$ref": "#/$defs/semanticVersion"
    },
    "collector_definition_digest": {
      "$ref": "#/$defs/sha256"
    },
    "state": {
      "type": "string",
      "enum": [
        "Planned",
        "NotTested",
        "BackendNotFound",
        "ConsentDenied",
        "PolicyRejected",
        "Running",
        "Succeeded",
        "Failed",
        "TimedOut",
        "Cancelled",
        "Partial"
      ]
    },
    "started_at": {
      "$ref": "#/$defs/timestamp"
    },
    "ended_at": {
      "$ref": "#/$defs/timestamp"
    },
    "privilege": {
      "type": "string",
      "enum": [
        "StandardUser",
        "Elevated"
      ]
    },
    "consent_receipt_ids": {
      "type": "array",
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "applied_resource_limits": {
      "$ref": "#/$defs/resourceLimits"
    },
    "command_contract_id": {
      "type": "string",
      "pattern": "^command-contract:[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "expected_backend": {
      "$ref": "#/$defs/expectedBackend"
    },
    "backend_process": {
      "$ref": "#/$defs/observedBackend"
    },
    "exit_code": {
      "type": "integer",
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "output_digests": {
      "$ref": "#/$defs/outputDigests"
    },
    "parser_result": {
      "$ref": "#/$defs/terminalStageResult"
    },
    "import_result": {
      "$ref": "#/$defs/terminalStageResult"
    },
    "record_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000
    },
    "truncation": {
      "$ref": "#/$defs/truncationMarker"
    },
    "partial_reason": {
      "type": "string",
      "enum": [
        "OutputTruncated",
        "SourceFailure",
        "ParserPartial",
        "ImportPartial",
        "ResourceLimit"
      ]
    },
    "cancellation_source": {
      "type": "string",
      "enum": [
        "User",
        "Policy",
        "Orchestrator",
        "Backend"
      ]
    },
    "timeout_source": {
      "type": "string",
      "enum": [
        "Backend",
        "Orchestrator",
        "Import"
      ]
    },
    "failure": {
      "$ref": "error-object.schema.json"
    },
    "observation_ids": {
      "type": "array",
      "maxItems": 100000,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "errors": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "error-object.schema.json"
      }
    },
    "integrity": {
      "$ref": "#/$defs/objectIntegrity"
    }
  },
  "allOf": [
